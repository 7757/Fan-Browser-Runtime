{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "composite": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "references": [
    {
      "path": "../../packages/protocol"
    },
    {
      "path": "../../packages/runtime"
    },
    {
      "path": "../../packages/node-client"
    }
  ],
  "include": [
    "src/**/*.ts"
  ]
}
